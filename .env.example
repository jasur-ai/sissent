# ==============================================================
# guid_erbot - Environment Variables Configuration
# ==============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Then start the bot: python3 bot.py
# ==============================================================

# REQUIRED: Your Telegram Bot Token
# Get it from @BotFather on Telegram
BOT_TOKEN="your_bot_token_here"

# OPTIONAL: Admin User IDs (comma-separated)
# Find your ID by sending /whoami to the bot after setup
# Default: 8004724563
ADMIN_IDS="8004724563"

# OPTIONAL: VM Login Credentials (for lock/unlock)
OSBOXES_USER="osboxes"
OSBOXES_PASS="osboxes.org"

# OPTIONAL: Flask Web Panel Port (default: 5000)
WEB_PORT=5000
